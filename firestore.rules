rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // USERS
    // =========================
    match /users/{userId} {
      // TEMPORARY DIAGNOSTIC RULE: Allow all authenticated users to read profiles
      // We will tighten this back to admin-only once we confirm why the previous rule failed.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // =========================
    // LIVESTOCK (Marketplace)
    // =========================
    match /livestock/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.sellerId;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.sellerId;

      // =========================
      // COMMENTS (Subcollection)
      // =========================
      match /comments/{commentId} {
        allow read: if request.auth != null;
        
        // Allow any authenticated user to create a comment
        allow create: if request.auth != null;
        
        // Allow only the author to delete their own comment
        allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }

    // =========================
    // ANNOUNCEMENTS
    // =========================
    match /announcements/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.postedBy;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.postedBy;
    }

    // =========================
    // FEEDING INFORMATION
    // =========================
    match /feeding_info/{docId} {
      allow read: if request.auth != null;

      // Only ADMIN can write feeding info
      allow create, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // =========================
    // HEALTH GUIDELINES
    // =========================
    match /health_guidelines/{docId} {
      // Farmers + Admin can READ
      allow read: if request.auth != null;

      // Only ADMIN can ADD / UPDATE / DELETE
      allow create, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // =========================
    // CHATS & MESSAGES
    // =========================
    match /chats/{chatId} {
      // Allow read/write if the user is a participant
      allow read: if request.auth != null && (
        resource == null || request.auth.uid in resource.data.participants
      );
      
      allow write: if request.auth != null && (
        // For creation, check request.resource
        (resource == null && request.auth.uid in request.resource.data.participants) ||
        // For updates, check existing resource
        (resource != null && request.auth.uid in resource.data.participants)
      );

      match /messages/{messageId} {
        // Messages are readable/writable if user is part of the parent chat
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // =========================
    // NOTIFICATIONS
    // =========================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      // The rule checks if the userId field in the document matches the authenticated user
      allow read: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // Users can update their own notifications (to mark as read)
      allow update: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // Any authenticated user can create notifications (system creates them for users)
      // Ensure userId is set in the notification
      allow create: if request.auth != null && 
        request.resource.data.userId != null;
    }

  }
}
